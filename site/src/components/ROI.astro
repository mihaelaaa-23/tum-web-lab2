---
import roiData from '../../content/roi/index.json';
const { headline, subtext, badgeText, stats } = roiData;
---

<section id="roi" class="bg-gradient-to-br from-[#026E82] to-[#024959] py-8 md:py-12 scroll-animate">
  <div class="container max-w-[1100px] mx-auto px-4">
    <h2 class="font-accent text-white italic text-2xl sm:text-3xl md:text-5xl text-center mb-4 font-medium px-2">
      {headline}
    </h2>
    <p class="text-white/90 text-center max-w-[800px] mx-auto mb-8 text-sm md:text-base">
      {subtext}
    </p>
    <div class="bg-white/10 backdrop-blur-sm border border-white/20 rounded-3xl p-6 md:p-10 max-w-[800px] mx-auto">
      <div class="text-center mb-6">
        <div class="inline-block bg-[#CDB181] text-[#1a1a1a] px-6 py-2 rounded-full font-bold text-sm md:text-base mb-4">
          {badgeText}
        </div>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4 md:gap-6 text-center">
        {stats.map((stat, i) => (
          <div class="holographic-card bg-white/5 border border-white/10 rounded-2xl p-5 transition-all">
            <div class={`text-4xl md:text-5xl font-extrabold text-[#CDB181] mb-2 roi-glow${i > 0 ? ` roi-glow-delay-${i}` : ''}`}>
              {stat.value}
            </div>
            <p class="text-white text-sm">{stat.label}</p>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>