---
import resultsData from '../../content/results/index.json';
const { headline, subtext, cases: allCases } = resultsData;
const cases = allCases.filter((c: any) => !c.hidden);
---

<section id="results-video" class="bg-white py-8 md:py-10 scroll-mt-20 scroll-animate">
  <div class="container max-w-[1100px] mx-auto px-4">
    <h2 class="font-accent text-primary italic text-3xl md:text-5xl text-center mb-3 font-medium">
      {headline}
    </h2>
    <p class="text-center text-gray-600 mb-6 md:mb-7 max-w-[650px] mx-auto text-sm md:text-base px-2 leading-relaxed">
      {subtext}
    </p>
    <div class="flex flex-col md:flex-row justify-center gap-4 mt-6 md:mt-8 items-center">
      {cases.map((c) => (
        <a href={c.href} target="_blank"
          class="stagger-item w-full max-w-[280px] md:flex-1 md:min-w-[220px] md:max-w-[250px] relative no-underline text-dark text-center group">
          <div class="relative transition-all duration-300 md:group-hover:-translate-y-2 md:group-hover:shadow-2xl rounded-xl">
            <img src={`${import.meta.env.BASE_URL}${c.thumb.replace(/^\//, '')}`} alt={c.name}
              class="w-full aspect-[9/16] object-cover rounded-xl" />
            <div class="absolute bottom-0 left-0 right-0 bg-gradient-to-t from-black/70 to-transparent rounded-b-xl py-2 px-3">
              <p class="text-white text-xs font-semibold">{c.category}</p>
            </div>
          </div>
          <p class="mt-2.5 text-sm font-semibold">{c.name}</p>
          <p class="text-xs text-gray-600">{c.stat} | <span class="text-green-600">● ACTIV</span></p>
        </a>
      ))}
    </div>
  </div>
</section>