---
import clientsData from '../../content/clients/index.json';
const { headline, subtext, clients: allClients } = clientsData;
const clients = allClients.filter((c: any) => !c.hidden);
---

<section id="trusted-clients" class="bg-white py-12 md:py-16 scroll-mt-20 overflow-hidden scroll-animate">
  <div class="container max-w-[1100px] mx-auto px-4">
    <h2 class="font-accent text-3xl md:text-5xl text-primary mb-3 text-center font-medium italic">
      {headline}
    </h2>
    <p class="text-center text-gray-600 mb-10 md:mb-14 max-w-2xl mx-auto">
      {subtext}
    </p>
  </div>
  <div class="clients-scroll-wrapper">
    <div class="clients-track">
      {[...clients, ...clients].map((c) => (
        <div class="client-logo">
          <div class="logo-wrapper">
            <img src={`${import.meta.env.BASE_URL}${c.img.replace(/^\//, '')}`} alt={c.alt} />
          </div>
        </div>
      ))}
    </div>
  </div>
</section>